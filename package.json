{
  "name": "qai",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "contracts",
    "."
  ],
  "scripts": {
    "dev": "next dev",
    "dev:clean": "npx --yes kill-port 3000 && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "contracts:compile": "cd contracts && npx hardhat compile",
    "contracts:test": "cd contracts && npx hardhat test",
    "contracts:deploy": "cd contracts && npx hardhat run scripts/deploy.ts --network zerog_testnet",
    "contracts:deploy:local": "cd contracts && npx hardhat run scripts/deploy.ts --network localhost"
  },
  "dependencies": {
    "@0glabs/0g-ts-sdk": "^0.3.1",
    "@rainbow-me/rainbowkit": "^2.2.0",
    "@react-three/drei": "^9.114.3",
    "@react-three/fiber": "^8.17.14",
    "@tanstack/react-query": "^5.51.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "ethers": "^6.13.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.414.0",
    "next": "14.2.5",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^2.4.0",
    "three": "^0.183.2",
    "viem": "^2.17.5",
    "wagmi": "^2.12.7",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/three": "^0.165.0",
    "autoprefixer": "^10",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "tailwindcss": "^3",
    "typescript": "^5"
  }
}
