# ============================================================
# QAI — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Blockchain ──────────────────────────────────────────────
# Deployed contract addresses (populated by deploy script)
NEXT_PUBLIC_AGENT_REGISTRY_ADDRESS=
NEXT_PUBLIC_MEMORY_ANCHOR_ADDRESS=

# 0G Testnet RPC
NEXT_PUBLIC_ZEROG_RPC_URL=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_ZEROG_CHAIN_ID=16601

# WalletConnect Project ID (get one at cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── 0G Storage ──────────────────────────────────────────────
# 0G Storage node endpoint
ZEROG_STORAGE_NODE_URL=https://storage.0g.ai
NEXT_PUBLIC_ZEROG_STORAGE_NODE_URL=https://storage.0g.ai

# 0G Storage KV contract address (provided by 0G team).
# Session persistence to KV + log also requires INFERENCE_GATEWAY_PRIVATE_KEY below.
NEXT_PUBLIC_ZEROG_KV_CONTRACT=

# ── 0G Compute ──────────────────────────────────────────────
# Inference endpoint provided by 0G Compute network
ZEROG_COMPUTE_ENDPOINT=

# Optional API key if your 0G Compute deployment requires it (sent as X-API-Key)
ZEROG_COMPUTE_API_KEY=

# ── Inference ───────────────────────────────────────────────
# Server-side only: private key for signing MemoryAnchor transactions
# This is the inference gateway signing key — keep it secret
INFERENCE_GATEWAY_PRIVATE_KEY=

# Rate limiting (requests per wallet per minute)
RATE_LIMIT_RPM=20

# ── Deployer (contracts only) ───────────────────────────────
# Used only by Hardhat deploy script — never used by the frontend
DEPLOYER_PRIVATE_KEY=
